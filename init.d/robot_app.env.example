# /userdata/robot_app.env  (per-device, NOT committed to git)
#
# Copy this to /userdata/robot_app.env on each robot and fill in real values.
# The boot hook (/data/cfg/rockchip_test/power_lost_test.sh) sources this
# file and passes the variables as -ntrip-* flags to robot_app.
#
# Pull these from your own device's runtime log:
#   adb shell "grep 'RTK token' /userdata/logs/frodobots.log | tail -1"

NTRIP_HOST=rtk.example.com
NTRIP_PORT=2101
NTRIP_MOUNT=AUTO
NTRIP_USER=your_username_here
NTRIP_PASS=your_password_here
